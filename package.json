{
  "name": "crm-cetreria",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules node_modules/.vite",
    "reinstall": "npm run clean && npm install",
    "preflight": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/preflight-wire.ts",
    "preflight:check": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/preflight-wire.ts --check",
    "preflight:ci": "cross-env DB_PATH=backend/data/fixtures/preflight-ci.db.json npm run preflight:check",
    "preflight:fixture": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/build-preflight-ci-fixture.ts",
    "check-ports": "tsx scripts/check-ports.ts",
    "setup-db": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/setup-db.ts",
    "recover-documents": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/recover-orphan-document-pdfs.ts",
    "audit:invoice-delivery-note-pairs": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/audit-invoice-delivery-note-pairs.ts",
    "fix:invoice-delivery-note-pairs": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/audit-invoice-delivery-note-pairs.ts --fix",
    "embed:document-brand": "node scripts/embed-document-brand-assets.mjs",
    "dev:prepare": "npm run preflight:check && npm run check-ports",
    "predev": "npm run dev:prepare",
    "dev:backend": "cross-env NODE_OPTIONS=--max-http-header-size=32768 tsx --tsconfig backend/tsconfig.json backend/src/server.ts",
    "dev:wait-api": "tsx scripts/wait-for-api.ts",
    "dev:frontend": "cross-env NODE_OPTIONS=--max-http-header-size=32768 vite --config frontend/vite.config.ts",
    "dev:wait-and-frontend": "npm run dev:wait-api && npm run dev:frontend",
    "dev": "concurrently -k -n backend,ui \"npm run dev:backend\" \"npm run dev:wait-and-frontend\"",
    "prestart": "npm run setup-db",
    "start": "cross-env NODE_OPTIONS=--max-http-header-size=32768 tsx --tsconfig backend/tsconfig.json backend/src/server.ts",
    "typecheck:backend": "tsc --noEmit -p backend/tsconfig.json",
    "test": "node --import tsx --test --test-concurrency=1 shared/tests/*.test.ts backend/src/db/jsonFileStore.test.ts backend/src/db/storeFactory.test.ts backend/src/db/exportLowdb.test.ts backend/src/db/documentTypeGroups.read.test.ts backend/src/db/clientGroups.read.test.ts backend/src/services/documentsBootstrap.read.test.ts backend/src/services/workspaceFeatureSettings.test.ts backend/src/services/verifactu.test.ts backend/src/services/electronicInvoicing/electronicInvoicingGate.test.ts backend/src/services/electronicInvoicing/providers/esVerifactu/esVerifactuCertificateHealth.test.ts backend/src/services/electronicInvoicing/providers/esVerifactu/esVerifactuProvider.test.ts backend/src/services/aeat/verifactuAeatCore.test.ts backend/src/services/aeat/buildVerifactuNormativeRecordHash.test.ts backend/src/services/aeat/verifactuAeatConfig.test.ts backend/src/services/aeat/verifactuAeatSubmit.test.ts backend/src/services/aeat/verifactuAeatXml.test.ts backend/src/services/aeat/verifactuAeatXades.test.ts backend/src/routes/documents.bootstrap.smoke.test.ts backend/src/routes/documents.verifactu.smoke.test.ts backend/src/routes/documents.electronicInvoicing.smoke.test.ts backend/src/routes/electronicInvoicing.health.smoke.test.ts backend/src/routes/workspaceFeatureSettings.smoke.test.ts backend/src/services/notifications.dedupe.test.ts backend/src/storage/blobConfig.test.ts backend/src/vercel/dbRemoteSync.test.ts",
    "export-lowdb": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/export-lowdb.ts",
    "test:verifactu": "node --import tsx --test --test-concurrency=1 shared/tests/verifactu.test.ts shared/tests/workspaceFeatureSettings.test.ts shared/tests/verifactuSettingsToggleContract.test.ts backend/src/services/workspaceFeatureSettings.test.ts backend/src/services/verifactu.test.ts backend/src/services/electronicInvoicing/electronicInvoicingGate.test.ts backend/src/services/electronicInvoicing/providers/esVerifactu/esVerifactuCertificateHealth.test.ts backend/src/services/electronicInvoicing/providers/esVerifactu/esVerifactuProvider.test.ts backend/src/services/aeat/verifactuAeatCore.test.ts backend/src/services/aeat/buildVerifactuNormativeRecordHash.test.ts backend/src/services/aeat/verifactuAeatConfig.test.ts backend/src/services/aeat/verifactuAeatSubmit.test.ts backend/src/services/aeat/verifactuAeatXml.test.ts backend/src/services/aeat/verifactuAeatXades.test.ts backend/src/routes/documents.verifactu.smoke.test.ts backend/src/routes/documents.electronicInvoicing.smoke.test.ts backend/src/routes/electronicInvoicing.health.smoke.test.ts backend/src/routes/workspaceFeatureSettings.smoke.test.ts",
    "smoke:verifactu-aeat": "tsx --tsconfig backend/tsconfig.json backend/src/scripts/smoke-verifactu-aeat.ts",
    "test:verifactu:aeat-core": "node --import tsx --test --test-concurrency=1 backend/src/services/aeat/verifactuAeatCore.test.ts",
    "smoke:documents-bootstrap": "node --import tsx --test --test-concurrency=1 backend/src/routes/documents.bootstrap.smoke.test.ts",
    "test:resource-access": "node --import tsx --test shared/tests/resourceAccess.test.ts",
    "build": "vite build --config frontend/vite.config.ts && node scripts/bundle-api.mjs",
    "build:vercel": "node scripts/build-vercel.mjs",
    "test:deploy": "node --import tsx --test --test-concurrency=1 backend/src/routes/workspaceSettingsAuth.smoke.test.ts backend/src/routes/notificationsWsHttp.smoke.test.ts frontend/src/lib/workspaceScopedFetchGate.test.ts frontend/src/lib/notificationsRealtime.test.ts",
    "ci:demo": "npm run preflight:ci && npm run typecheck:backend && npm test && npm run test:deploy && npm run build",
    "smoke:demo-deploy": "tsx --tsconfig backend/tsconfig.json scripts/verify-demo-deploy.ts",
    "preview": "cross-env NODE_OPTIONS=--max-http-header-size=32768 vite preview --config frontend/vite.config.ts",
    "tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflared-tunnel.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@aws-sdk/s3-request-presigner": "^3.1056.0",
    "@emoji-mart/data": "^1.2.1",
    "@peculiar/webcrypto": "^1.7.1",
    "@shared/types": "file:./shared",
    "@vercel/blob": "^2.4.1",
    "@xmldom/xmldom": "^0.8.13",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.487.0",
    "node-forge": "^1.4.0",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.4.1",
    "recharts": "^3.8.1",
    "tesseract.js": "^6.0.1",
    "ws": "^8.21.0",
    "xadesjs": "^2.6.7",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.1",
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@types/xmldom": "^0.1.34",
    "@vercel/node": "^5.1.14",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.3"
  }
}
