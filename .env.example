# =============================================================================
# Local dev (npm run dev)
# =============================================================================

# Puertos: 3000 frontend (Vite), 3001 API Express
FRONTEND_PORT=3000
PORT=3001
# HOST=0.0.0.0

# Base de datos JSON local
DB_TYPE=json
DATABASE_PROVIDER=json
# DB_PATH=/ruta/absoluta/db.json

# Frontend: en dev basta /api (proxy Vite). En Vercel dejar vacio o /api
# VITE_API_URL=/api

JWT_SECRET=crm-cetreria-dev-secret

# Almacenamiento PDFs (produccion: S3 obligatorio en Vercel)
S3_BUCKET=
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# DB_S3_KEY=crm-cetreria/db.json
# S3_ENDPOINT=
# S3_PRESIGN_EXPIRES=3600
# DOCUMENT_STORAGE_DIR=/ruta/absoluta/document-pdfs

# Veri*Factu (desactivado por defecto)
# VERIFACTU_MODULE_ENABLED=true

# =============================================================================
# Vercel (Settings -> Environment Variables)
# Copiar con: vercel env pull .env.local
# =============================================================================

# Obligatorias en produccion
# JWT_SECRET=<secreto-fuerte>
# S3_BUCKET=<bucket>
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1

# Frontend (misma origin; no hace falta URL absoluta)
# VITE_API_URL=/api

# Persistencia db.json en serverless (usa el bucket S3 anterior)
# DB_S3_KEY=crm-cetreria/db.json

# Reservado / futuro (no usado por el backend JSON actual)
# DATABASE_URL=
# KV_URL=

# Integraciones Meta (reservado; no cableado en backend hoy)
# META_APP_ID=
# META_APP_SECRET=
# META_REDIRECT_URI=
