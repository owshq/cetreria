# Puertos (bloque 3000)
# - 3000: frontend (Vite). Las peticiones a /api se reenvían al backend.
# - 3001: API Express + base de datos JSON (no hay un puerto DB aparte).
FRONTEND_PORT=3000
PORT=3001
# HOST=0.0.0.0

# Base de datos local JSON (futuro: cloud, postgres, etc.)
DB_TYPE=json
# DB_PATH=/ruta/absoluta/db.json

# Frontend: en dev basta con /api (proxy de Vite → backend). Para acceso directo:
# VITE_API_URL=http://localhost:3001/api

# JWT
JWT_SECRET=crm-cetreria-dev-secret

# Almacenamiento de PDFs de documentos (facturas/albaranes)
# En producción: configurar S3. Sin S3_BUCKET se usa almacenamiento local en backend/data/document-pdfs/
S3_BUCKET=
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: endpoint compatible S3 (MinIO, LocalStack, etc.)
# S3_ENDPOINT=
# S3_PRESIGN_EXPIRES=3600
# DOCUMENT_STORAGE_DIR=/ruta/absoluta/document-pdfs
